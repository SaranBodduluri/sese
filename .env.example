# Server-only: Gemini (never use NEXT_PUBLIC_ for API keys).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional model override (default in app: gemini-2.0-flash).
# GEMINI_MODEL="gemini-2.0-flash"

# Server-only: ElevenLabs TTS (see lib/tts/elevenlabs.ts).
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# App URL for client-side links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
