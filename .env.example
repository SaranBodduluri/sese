# Server-only: Gemini (never use NEXT_PUBLIC_ for API keys).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional model override (default in app: gemini-2.5-flash).
# GEMINI_MODEL="gemini-2.5-flash"

# Server-only: ElevenLabs TTS (see lib/tts/elevenlabs.ts).
# ELEVENLABS_API_KEY=
# Default in app: Domi (energetic female). Override with any voice ID from your ElevenLabs library.
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# ELEVENLABS_TTS_STABILITY=0.32
# ELEVENLABS_TTS_STYLE=0.72
# ELEVENLABS_TTS_SPEED=1.1
# ELEVENLABS_TTS_SPEAKER_BOOST=true

# Client: tutor voice (see lib/config.ts).
# NEXT_PUBLIC_TTS_ENABLED=true
# NEXT_PUBLIC_AUTO_PLAY_TUTOR_AUDIO=true
# NEXT_PUBLIC_BROWSER_TTS_FALLBACK=true

# App URL for client-side links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (optional: textbook PDF ingest + vector retrieval + session persistence) ---
# Dashboard → Project Settings → API:
#   - Project URL → NEXT_PUBLIC_SUPABASE_URL (https://xxxx.supabase.co)
#   - service_role (secret) → SUPABASE_SERVICE_ROLE_KEY (long JWT starting with eyJ... — server only)
# Do NOT use the short hyphenated "database password" as SUPABASE_SERVICE_ROLE_KEY.
# Run supabase/migrations/001_sese_grounding.sql in the SQL editor after the project exists.
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# Optional: direct Postgres password (for CLI/psql/migrations only — not used by the Next.js app today)
# SUPABASE_DB_PASSWORD=
